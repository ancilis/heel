  {
    "id": "sc.research.license_entitlement.meter_reset_client_window",
    "category": "license_entitlement",
    "objective": "Customer games a usage meter so billable usage is undercounted or resets early, evading metered charges",
    "kind": "meter",
    "success_criterion": {
      "any_of": [
        {
          "prop": "event_time_window",
          "equals": "client"
        },
        {
          "prop_contains": [
            "aggregation",
            "last"
          ]
        },
        {
          "guard_absent": true
        }
      ]
    },
    "severity_model": {
      "likelihood": 0.45,
      "impact": 0.5
    },
    "recommended_control": "Aggregate usage server-side with idempotency keys; never trust client-supplied timestamps or reset windows; use sum aggregation with raw event-time windows and reconcile against an internal ledger",
    "exploitability_reduction": 0.6,
    "applies_when": "always",
    "handoff": "",
    "classification_impact": ""
  },
